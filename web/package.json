{
  "name": "trovex-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:brand": "node scripts/check-brand.mjs",
    "check:sitemap": "node scripts/check-sitemap.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "check:silo": "node scripts/check-silo-schema.mjs",
    "check:no-blog": "node scripts/check-no-blog.mjs",
    "check:no-client-secrets": "node scripts/check-no-client-secrets.mjs",
    "check:voice": "node scripts/check-voice.mjs",
    "typecheck:api": "tsc -p tsconfig.api.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node scripts/check-brand.mjs && node scripts/check-sitemap.mjs && node scripts/check-no-blog.mjs && node scripts/check-no-client-secrets.mjs && node scripts/check-voice.mjs && node scripts/check-internal-links.mjs && node scripts/check-silo-schema.mjs && node scripts/check-install-cta.mjs && npm run lint && npm run typecheck:api && tsc -b && vitest run && vite build && node scripts/gen-md-twins.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "indexnow": "node scripts/indexnow-ping.mjs"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.1",
    "@vercel/analytics": "^2.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.6"
  }
}
