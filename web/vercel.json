{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/beta", "destination": "/", "permanent": true },
    { "source": "/beta/", "destination": "/", "permanent": true },
    { "source": "/blog", "destination": "https://tsukumo.ch/blog", "permanent": true },
    { "source": "/blog/(.*)", "destination": "https://tsukumo.ch/blog/$1", "permanent": true }
  ],
  "rewrites": [
    { "source": "/js/script.js", "destination": "https://plausible.io/js/script.js" },
    { "source": "/api/event", "destination": "https://plausible.io/api/event" },
    { "source": "/savings", "destination": "/api/savings" }
  ],
  "functions": {
    "api/savings-card.js": { "includeFiles": "api/_fonts/**" }
  }
}
